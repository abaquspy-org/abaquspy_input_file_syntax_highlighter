{
  "scopeName": "source.abaqus",

  "patterns": [
    { "include": "#keywords" },
    { "include": "#kv_pairs" },
    { "include": "#python_block" }
  ],

  "repository": {

    "keywords": {
      "patterns": [
        {
          "match": "^\\s*\\*\\*.*?\\*\\*\\s*$",
          "name": "comment.line.abaqus"
        },
        {
          "match": "^\\s*\\*[^,\\r\\n]+",
          "name": "keyword.control.abaqus"
        },
        {
          "match": "\\$",
          "name": "punctuation.definition.dollar.abaqus"
        }
      ]
    },

    "dollar_output": {
      "patterns": [
        {
          "match": "\\*\\*.*?\\*\\*\\s*$",
          "name": "comment.line.abaqus"
        },
        {
          "match": "\\*[^,\\r\\n]+",
          "name": "keyword.control.abaqus"
        },
        {
          "include": "#kv_pairs"
        }
      ]
    },

    "kv_pairs": {
      "patterns": [
        {
          "match": "(\\b[A-Z_]+(?:\\s+[A-Z_]+)*\\s*=)([^,\\n\\r]+)",
          "captures": {
            "1": {
              "name": "support.constant.parameter.abaqus"
            },
            "2": {
              "name": "string.unquoted.value.abaqus"
            }
          }
        },
        {
          "match": "(?<=,\\s*)(NLGEOM|ADD|REMOVE|FIXED|USER|FOLLOWER|FIELD|HISTORY|GENERATE|NONLINEAR)(?=\\s*(?:,|$))",
          "captures": {
            "1": {
              "name": "string.unquoted.value.abaqus"
            }
          }
        }
      ]
    },

    "python_block": {
      "name": "meta.embedded.block.python.abaqus",

      "begin": "(<py\\b)",
      "beginCaptures": {
        "1": {
          "name": "entity.name.tag.python.abaqus"
        }
      },

      "end": "(py>)",
      "endCaptures": {
        "1": {
          "name": "entity.name.tag.python.abaqus"
        }
      },

      "patterns": [
        {
          "begin": "^(\\s*\\$)\\s*",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.dollar.abaqus"
            }
          },
          "end": "$",
          "patterns": [
            {
              "include": "#dollar_output"
            }
          ]
        },
        {
          "match": "\\$",
          "name": "punctuation.definition.dollar.abaqus"
        },
        {
          "include": "source.python"
        }
      ]
    }
  }
}